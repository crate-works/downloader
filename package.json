{
  "name": "arocapi-downloader",
  "version": "1.14.1",
  "description": "RO-Crate based collection downloader",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "test": "vitest",
    "lint:biome": "biome check .",
    "lint:types": "tsc --noEmit",
    "lint:knip": "knip",
    "docker:build": "docker build -t arocapi-downloader:test .",
    "docker:run": "docker run --rm -p 5173:7000 --env-file .env arocapi-downloader:test",
    "docker:test": "pnpm docker:build && pnpm docker:run"
  },
  "keywords": [
    "ro-crate",
    "downloader",
    "archive"
  ],
  "author": "John Ferlito <johnf@inodes.org>",
