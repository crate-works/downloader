---
import FeatureCard from '../components/FeatureCard.astro';
import FlowDiagram from '../components/FlowDiagram.astro';
import Hero from '../components/Hero.astro';
import Screenshot from '../components/Screenshot.astro';
import { DOCKER_IMAGE, GITHUB_URL, PARADISEC_URL, ROCRATE_API_URL, SITE_TAGLINE } from '../consts';
import Base from '../layouts/Base.astro';
---

<Base>
  <Hero eyebrow="Open source · RO-Crate" title="Browse research archives. Download exactly what you need." subtitle={SITE_TAGLINE}>
    <a
      slot="actions"
      href="/guide/"
      class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700"
    >
      See how it works
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </a>
    <a
      slot="actions"
      href="/self-hosting/"
      class="inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-slate-400 hover:bg-slate-50"
    >
      Deploy it yourself
    </a>
    <a
      slot="actions"
      href={GITHUB_URL}
      rel="noopener"
      class="inline-flex items-center gap-2 px-2 py-3 text-sm font-semibold text-slate-600 transition-colors hover:text-slate-900"
    >
      View on GitHub
    </a>
  </Hero>

  <!-- What it is -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">A friendly front door to RO-Crate collections</h2>
        <div class="mt-5 space-y-4 text-lg text-slate-600">
          <p>
            Research archives like <a href={PARADISEC_URL} rel="noopener" class="font-medium text-brand-600 hover:underline">PARADISEC</a>
            hold thousands of digitised recordings of endangered languages and cultures. The Collection Downloader gives people a simple way to explore that
            material — without needing to understand the API behind it.
          </p>
          <p>
            It reads collections from any
            <a href={ROCRATE_API_URL} rel="noopener" class="font-medium text-brand-600 hover:underline">RO-Crate API</a>, lets you drill down from collections
            to items to individual files, and hands you a tidy zip of just the files you chose — delivered as a download link by email.
          </p>
        </div>
        <dl class="mt-8 grid grid-cols-2 gap-6 sm:max-w-md">
          <div>
            <dt class="text-sm text-slate-500">Browse hierarchy</dt>
            <dd class="text-lg font-semibold text-slate-900">Collections → Items → Files</dd>
          </div>
          <div>
            <dt class="text-sm text-slate-500">Delivery</dt>
            <dd class="text-lg font-semibold text-slate-900">Zip via email link</dd>
          </div>
        </dl>
      </div>
      <Screenshot
        src="/screenshots/search.png"
        alt="The collection browser showing the search results and facet sidebar"
        caption="The hierarchical browser with faceted search."
      />
    </div>
  </section>

  <!-- Features -->
  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">Everything you need to find and grab files</h2>
        <p class="mt-4 text-lg text-slate-600">Built for large media archives, where file sizes and formats matter.</p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <FeatureCard title="Hierarchical browser">
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            width="22"
            height="22"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m3 7 9-4 9 4-9 4-9-4Zm0 5 9 4 9-4M3 17l9 4 9-4"></path>
          </svg>
          Navigate collections, items and files with expand and collapse — the whole archive structure at your fingertips.
        </FeatureCard>
        <FeatureCard title="Quality tier filtering">
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            width="22"
            height="22"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"></path>
          </svg>
          Choose archival formats (WAV, MKV, MXF, TIFF) or compressed ones (MP3) — grab masters or lightweight copies.
        </FeatureCard>
        <FeatureCard title="File size tracking">
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            width="22"
            height="22"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 3v18h18M7 16l4-4 3 3 5-6"></path>
          </svg>
          See sizes at the file, item and collection level, with running totals as you build your selection.
        </FeatureCard>
        <FeatureCard title="Background export">
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            width="22"
            height="22"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path>
          </svg>
          Selected files are zipped and uploaded in the background, then a download link lands in your inbox.
        </FeatureCard>
      </div>
    </div>
  </section>

  <!-- Flow -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900">From collection to inbox</h2>
      <p class="mt-4 text-lg text-slate-600">Four steps from opening the browser to receiving your files.</p>
    </div>
    <div class="mt-14">
      <FlowDiagram />
    </div>
  </section>

  <!-- Self-host CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-8 sm:px-6">
    <div class="overflow-hidden rounded-3xl bg-gradient-to-br from-brand-700 to-brand-900 px-8 py-14 text-center sm:px-16">
      <h2 class="text-3xl font-bold tracking-tight text-white">Run it for your own archive</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
        Ships as a multi-arch Docker image. Point it at your RO-Crate API, an OIDC provider, an S3 bucket and SES — and you are live.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/self-hosting/"
          class="inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3 text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
        >
          Read the self-hosting guide
        </a>
        <code class="rounded-xl bg-brand-950/40 px-4 py-3 font-mono text-sm text-brand-100"> docker pull {DOCKER_IMAGE} </code>
      </div>
    </div>
  </section>
</Base>
