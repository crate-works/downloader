---
import { APP_VERSION, GITHUB_URL, NAV_LINKS, PARADISEC_URL, ROCRATE_URL, SITE_NAME } from '../consts';
---

<footer class="mt-24 border-t border-slate-200 bg-slate-50">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-12 sm:px-6 md:flex-row md:justify-between">
    <div class="max-w-sm">
      <div class="flex items-center">
        <span class="font-semibold text-slate-900">{SITE_NAME}</span>
      </div>
      <p class="mt-3 text-sm text-slate-500">
        Open-source software for browsing and downloading
        <a href={ROCRATE_URL} rel="noopener" class="text-brand-600 underline-offset-2 hover:underline">RO-Crate</a>
        research collections.
      </p>
    </div>

    <div class="flex gap-12 text-sm">
      <div>
        <h2 class="font-semibold text-slate-900">Pages</h2>
        <ul class="mt-3 space-y-2">
          {NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-600 hover:text-brand-600"
                >
                  {link.label}
                </a>
              </li>
            ))}
        </ul>
      </div>
      <div>
        <h2 class="font-semibold text-slate-900">Project</h2>
        <ul class="mt-3 space-y-2">
          <li>
            <a href={GITHUB_URL} rel="noopener" class="text-slate-600 hover:text-brand-600"> Source &amp; releases </a>
          </li>
          <li>
            <a href={PARADISEC_URL} rel="noopener" class="text-slate-600 hover:text-brand-600"> PARADISEC </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-5 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      <p>Documented against app version {APP_VERSION}.</p>
      <p>Released under the ISC licence.</p>
    </div>
  </div>
</footer>
