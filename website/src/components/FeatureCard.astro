---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="group relative rounded-2xl border border-slate-200 bg-white p-6 transition-all hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/50">
  <div
    class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-600 ring-1 ring-brand-100 transition-colors group-hover:bg-brand-100"
  >
    <slot name="icon" />
  </div>
  <h3 class="mt-5 text-base font-semibold text-slate-900">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">
    <slot />
  </p>
</div>
