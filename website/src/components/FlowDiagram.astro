---
// Visualises the end-to-end flow: browse the hierarchy, select files, the
// background processor zips + uploads, and a download link arrives by email.
const steps = [
  {
    label: 'Browse',
    sub: 'Collections → Items → Files',
    icon: 'm3 7 9-4 9 4-9 4-9-4Zm0 5 9 4 9-4M3 17l9 4 9-4',
  },
  { label: 'Select', sub: 'Filter by quality tier', icon: 'M20 6 9 17l-5-5' },
  {
    label: 'Export',
    sub: 'Zipped & uploaded to S3',
    icon: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3',
  },
  {
    label: 'Email',
    sub: 'Presigned download link',
    icon: 'M4 4h16v16H4zM4 7l8 5 8-5',
  },
] as const;
---

<div class="flex flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-between">
  {steps.map((step, i) => (
      <>
        <div class="flex flex-1 flex-col items-center gap-3 rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 ring-1 ring-brand-100">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={step.icon} />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-slate-900">{step.label}</p>
            <p class="mt-0.5 text-xs text-slate-500">{step.sub}</p>
          </div>
        </div>
        {i < steps.length - 1 && (
          <svg
            viewBox="0 0 24 24"
            width="22"
            height="22"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mx-auto flex-none rotate-90 text-brand-300 sm:rotate-0"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        )}
      </>
    ))}
</div>
