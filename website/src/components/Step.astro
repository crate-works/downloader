---
interface Props {
  n: number;
  title: string;
}

const { n, title } = Astro.props;
---

<li class="relative flex gap-5 pb-10 last:pb-0">
  <!-- connector line -->
  <div aria-hidden="true" class="absolute top-11 bottom-0 left-[1.375rem] w-px bg-slate-200 last:hidden"></div>
  <div class="z-10 flex h-11 w-11 flex-none items-center justify-center rounded-full bg-brand-600 text-base font-semibold text-white ring-4 ring-white">
    {n}
  </div>
  <div class="min-w-0 flex-1 pt-1.5">
    <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
    <div class="mt-2 space-y-4 text-slate-600">
      <slot />
    </div>
  </div>
</li>
